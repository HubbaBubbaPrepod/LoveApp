{
  "name": "loveapp-backend",
  "version": "2.0.0",
  "description": "Backend API for LoveApp - A couple's relationship tracking app",
  "main": "server.js",
  "scripts": {
    "start":     "node index.js",
    "start:old": "node server.js",
    "dev":       "nodemon index.js",
    "dev:old":   "nodemon server.js",
    "test":      "jest --detectOpenHandles --forceExit",
    "test:watch":"jest --watchAll",
    "migrate":   "node -e \"require('./src/db/migrate').runMigrations().then(() => process.exit(0))\"",
    "lint":      "eslint src/ --ext .js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:reload":"pm2 reload ecosystem.config.js --env production",
    "pm2:stop":  "pm2 stop ecosystem.config.js",
    "pm2:logs":  "pm2 logs loveapp-api"
  },
  "keywords": [
    "couple",
    "relationship",
    "tracker",
    "api",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^8.30.0",
    "@sentry/profiling-node": "^8.30.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.0.0",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "redis": "^4.6.14",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
