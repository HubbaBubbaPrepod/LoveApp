<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read images from gallery (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Fallback for Android 12 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- Required to post notifications on Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Keep screen on for lock-screen drawing -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Required for WorkManager to run as a foreground service (API 28+, Xiaomi MIUI) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required for lock-screen drawing notification (full-screen intent on lock screen) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Required on Android 14+ (API 34) when foregroundServiceType="specialUse" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Required to draw the floating button directly on the lock screen -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Allows WorkManager to re-schedule workers after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- System calendar access for CalendarExportManager -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <application
        android:name=".SimpleApplication"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LoveApp">

        <!-- Sentry: DSN for crash reporting. Auto-init disabled — manual init in SimpleApplication -->
        <meta-data
            android:name="io.sentry.dsn"
            android:value="https://503edf5c1972fa711ecf26665acaa789@o4510979258843136.ingest.de.sentry.io/4510979272147024" />
        <meta-data android:name="io.sentry.auto-init" android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LoveApp.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".SimpleMainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.LoveApp" />

        <!-- Mood day widget – Small (2×1) -->
        <receiver
            android:name=".widget.MoodWidgetSmallReceiver"
            android:exported="true"
            android:label="@string/widget_mood_small_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/mood_widget_small_info" />
        </receiver>

        <!-- Mood day widget – Medium (3×2) -->
        <receiver
            android:name=".widget.MoodDayWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_mood_medium_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/mood_day_widget_info" />
        </receiver>

        <!-- Mood day widget – Large (4×3) -->
        <receiver
            android:name=".widget.MoodWidgetLargeReceiver"
            android:exported="true"
            android:label="@string/widget_mood_large_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/mood_widget_large_info" />
        </receiver>

        <!-- Activity day widget – Small (2×1) -->
        <receiver
            android:name=".widget.ActivityWidgetSmallReceiver"
            android:exported="true"
            android:label="@string/widget_activity_small_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/activity_widget_small_info" />
        </receiver>

        <!-- Activity day widget – Medium (3×2) -->
        <receiver
            android:name=".widget.ActivityDayWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_activity_medium_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/activity_day_widget_info" />
        </receiver>

        <!-- Activity day widget – Large (4×3) -->
        <receiver
            android:name=".widget.ActivityWidgetLargeReceiver"
            android:exported="true"
            android:label="@string/widget_activity_large_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/activity_widget_large_info" />
        </receiver>

        <!-- Lock-screen drawing activity -->
        <activity
            android:name=".ui.art.LockScreenDrawingActivity"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:exported="false"
            android:theme="@style/Theme.LoveApp" />

        <!-- Lock-screen drawing persistent notification service -->
        <service
            android:name=".ui.art.LockScreenService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Persistent notification to open a drawing canvas from the lock screen without unlocking the device" />
        </service>

        <!-- Art widget – Small (2×2) -->
        <receiver
            android:name=".widget.ArtWidgetSmallReceiver"
            android:exported="true"
            android:label="@string/widget_art_small_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/art_widget_small_info" />
        </receiver>

        <!-- Art widget – Medium (3×3) -->
        <receiver
            android:name=".widget.ArtWidgetMediumReceiver"
            android:exported="true"
            android:label="@string/widget_art_medium_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/art_widget_medium_info" />
        </receiver>

        <!-- Art widget – Large (4×4) -->
        <receiver
            android:name=".widget.ArtWidgetLargeReceiver"
            android:exported="true"
            android:label="@string/widget_art_large_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/art_widget_large_info" />
        </receiver>

        <!-- Firebase Cloud Messaging -->
        <service
            android:name=".notifications.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!--
          Disable the default WorkManager auto-initializer so that our
          custom Hilt-aware Configuration.Provider (in SimpleApplication) is
          used instead.  Without this the default initializer runs first and
          ignores our HiltWorkerFactory.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.impl.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>